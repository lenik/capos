{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["affectedRows"],
  "properties": {
    "affectedRows": {
      "type": "integer",
      "minimum": 0
    },
    "lastInsertId": {
      "type": "string",
      "description": "Optional row id from INSERT (SQLite/Postgres dialect-dependent)."
    }
  }
}
