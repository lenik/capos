{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fileName",
    "contentType",
    "sizeBytes"
  ],
  "properties": {
    "fileName": {
      "type": "string",
      "minLength": 1
    },
    "contentType": {
      "type": "string"
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string"
    },
    "folder": {
      "type": "string"
    }
  }
}
