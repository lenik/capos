{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["sql", "parameters"],
  "properties": {
    "sql": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "maxRows": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000,
      "default": 1000
    }
  }
}
