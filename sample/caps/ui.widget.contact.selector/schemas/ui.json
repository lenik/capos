{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "widgetKind",
    "bindings"
  ],
  "properties": {
    "widgetKind": {
      "const": "contact.selector"
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "searchCapability",
        "valueField",
        "labelField"
      ],
      "properties": {
        "searchCapability": {
          "type": "string"
        },
        "getCapability": {
          "type": "string"
        },
        "valueField": {
          "type": "string"
        },
        "labelField": {
          "type": "string"
        }
      }
    }
  }
}
