{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/sample/caps/_shared/schemas/filter-clause.json",
  "title": "Single filter predicate",
  "type": "object",
  "additionalProperties": false,
  "required": ["field", "op"],
  "properties": {
    "field": { "type": "string" },
    "op": {
      "type": "string",
      "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "contains", "startsWith"]
    },
    "value": true
  }
}
