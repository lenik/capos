{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/samples/_shared/schemas/envelope-request.json",
  "title": "Optional cross-cutting request envelope",
  "description": "Wrap capability-specific payloads when platforms need correlation, locale, or tenant hints.",
