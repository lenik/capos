{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "assignee"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "assignee": {
      "type": "string"
    },
    "dueAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
