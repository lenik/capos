{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "salesOrderId",
    "warehouseId",
    "lines"
  ],
  "properties": {
    "salesOrderId": {
      "type": "string"
    },
    "warehouseId": {
      "type": "string"
    },
    "carrierCode": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "itemId",
          "quantity"
        ],
        "properties": {
          "itemId": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    }
  }
}
