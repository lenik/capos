{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "amount",
    "currency",
    "method"
  ],
  "properties": {
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "method": {
      "type": "string",
      "enum": [
        "card",
        "ach",
        "wire",
        "cash"
      ]
    },
    "invoiceId": {
      "type": "string"
    },
    "purchaseOrderId": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string"
    }
  }
}
