{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractId",
    "counterpartyId",
    "status",
    "startDate",
    "endDate"
  ],
  "properties": {
    "contractId": {
      "type": "string"
    },
    "counterpartyId": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "endDate": {
      "type": "string",
      "format": "date"
    }
  }
}
