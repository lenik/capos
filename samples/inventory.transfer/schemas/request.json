{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "itemId",
    "fromWarehouseId",
    "toWarehouseId",
    "quantity"
  ],
  "properties": {
    "itemId": {
      "type": "string"
    },
    "fromWarehouseId": {
      "type": "string"
    },
    "toWarehouseId": {
      "type": "string"
    },
    "quantity": {
      "type": "number",
      "exclusiveMinimum": 0
    }
  }
}
