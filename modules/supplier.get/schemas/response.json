{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "supplierId",
    "code",
    "name",
    "status"
  ],
  "properties": {
    "supplierId": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "blocked"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
