{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fileId"
  ],
  "properties": {
    "fileId": {
      "type": "string"
    },
    "variant": {
      "type": "string",
      "enum": [
        "thumb",
        "medium",
        "pdf"
      ]
    }
  }
}
