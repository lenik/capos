{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paymentId",
    "status"
  ],
  "properties": {
    "paymentId": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "processedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
