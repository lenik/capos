{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap.local/modules/_shared/schemas/page-response.json",
  "title": "Page metadata fragment",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nextCursor": {
      "type": "string",
      "description": "Pass as page.cursor on the next call, if more results exist."
    },
    "hasMore": { "type": "boolean" },
    "totalCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional exact total when cheap to compute."
    }
  }
}
