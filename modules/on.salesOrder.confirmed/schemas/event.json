{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "salesOrderId",
    "confirmedAt"
  ],
  "properties": {
    "salesOrderId": {
      "type": "string",
      "minLength": 1
    },
    "confirmedAt": {
      "type": "string",
      "format": "date-time"
    },
    "confirmedBy": {
      "type": "string"
    },
    "eventVersion": {
      "type": "integer",
      "minimum": 1
    }
  }
}
