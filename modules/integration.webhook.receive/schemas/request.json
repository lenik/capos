{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider",
    "eventId",
    "payload"
  ],
  "properties": {
    "provider": {
      "type": "string"
    },
    "eventId": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "signature": {
      "type": "string"
    },
    "receivedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
